# Kinness Backend Environment Variables
# Copy to .env and fill in values

PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Default facility code for new staff/family registrations
FACILITY_CODE=KINNESS2024

# Seed admin (created on first run if database is empty)
ADMIN_SEED_EMAIL=admin@kinness.app
ADMIN_SEED_PASSWORD=admin12345

# Auto-load Sunrise Gardens demo on startup if SGSL2024 missing (set on Render)
AUTO_SEED_DEMO=true

# Optional: POST /api/setup/pilot with header x-setup-secret (re-runs seed on Render)
# SETUP_SECRET=change-me

# SMTP (Nodemailer) — family update notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=Kinness <notifications@yourdomain.com>
SMTP_SECURE=false
