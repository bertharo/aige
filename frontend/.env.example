# Local dev: leave REACT_APP_API_URL unset — CRA proxies /api to http://localhost:3000
# Terminal 1: cd backend && npm run dev
# Terminal 2: cd frontend && npm start

# Override API (optional):
# REACT_APP_API_URL=http://localhost:3000

# Production builds default to https://aige-backend.onrender.com automatically.
# Override on Vercel if needed:
# REACT_APP_API_URL=https://aige-backend.onrender.com
