# Local dev: point at Express API
REACT_APP_API_URL=http://localhost:3000

# Vercel production: set KINNESS_BACKEND_URL in project env (e.g. https://your-app.railway.app)
# Leave REACT_APP_API_URL unset so the app uses same-origin /api (proxied at build time)
# KINNESS_BACKEND_URL=https://your-kinness-api.railway.app
