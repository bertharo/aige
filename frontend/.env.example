# Local dev: leave unset — CRA proxies /api to http://localhost:3000 (see package.json "proxy")
# Start backend first: cd backend && npm run dev
# Then frontend: cd frontend && npm start  (opens on port 3001 if 3000 is taken)

# Only set this if the API is on a different host (no CRA proxy):
# REACT_APP_API_URL=http://localhost:3000

# Vercel production: set in Vercel project settings (not in this file):
# KINNESS_BACKEND_URL=https://your-kinness-api.railway.app
